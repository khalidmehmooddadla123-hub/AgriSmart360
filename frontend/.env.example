# Supabase (required for email/Google auth & database)
VITE_SUPABASE_URL=https://ujpmqdmnphkulyftldsv.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenWeather API (required for live weather data)
# Get a free key at https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your-openweather-api-key

# Backend API URL (Express.js server – defaults to http://localhost:5000)
VITE_API_BASE_URL=http://localhost:5000

# Firebase (required for Phone/SMS OTP authentication)
# Create a Firebase project at https://console.firebase.google.com
# Enable Phone Authentication under Authentication > Sign-in methods
# Add your web app and copy the config values below
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Google OAuth is configured via Supabase Dashboard:
#   Authentication > Providers > Google
# Add your Google Client ID & Secret there – NOT here.

# Grok AI API (for AI chat assistant and disease detection)
# Get a key at https://console.x.ai
VITE_GROK_API_KEY=your-grok-api-key
